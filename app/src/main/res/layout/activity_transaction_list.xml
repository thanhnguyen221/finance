<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootTransactionList"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F8FA"
    android:fitsSystemWindows="true"
    android:clipToPadding="false">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_round"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:layout_margin="12dp"
        android:elevation="3dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/desc_back"
            app:srcCompat="@android:drawable/ic_media_previous"
            app:tint="#2C2C2C" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_transactions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textColor="#2C2C2C" />

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/label_filter"
            app:srcCompat="@android:drawable/ic_menu_sort_by_size"
            app:tint="#2C2C2C" />
    </LinearLayout>

    <!-- NỘI DUNG CHÍNH -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:layout_marginTop="84dp">

        <!-- CARD: Chọn loại & Chuyển ngày -->
        <LinearLayout
            android:id="@+id/cardTypeDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_round"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <!-- Loại giao dịch -->
            <RadioGroup
                android:id="@+id/rgType"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbExpense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chi tiêu"
                    android:layout_marginStart="8dp" />

                <RadioButton
                    android:id="@+id/rbIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thu nhập"
                    android:layout_marginStart="8dp" />
            </RadioGroup>

            <!-- Điều hướng ngày -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnPrevDay"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/section_today"
                    app:srcCompat="@android:drawable/ic_media_previous"
                    app:tint="#2C2C2C" />

                <TextView
                    android:id="@+id/tvDayTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="22/04/2022 • Thứ sáu"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:textColor="#2C2C2C" />

                <ImageButton
                    android:id="@+id/btnNextDay"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/section_today"
                    app:srcCompat="@android:drawable/ic_media_next"
                    app:tint="#2C2C2C" />
            </LinearLayout>

            <!-- Tổng thu/chi của ngày đang chọn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:text="@string/label_today_income"
                        android:textSize="12sp"
                        android:textColor="#7A7F8A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvDayIncome"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:text="@string/label_today_expense"
                        android:textSize="12sp"
                        android:textColor="#7A7F8A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvDayExpense"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD: Danh sách giao dịch -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_round"
            android:padding="8dp"
            android:elevation="2dp">

            <ListView
                android:id="@+id/lvTransactions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:listSelector="@android:color/transparent"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:padding="4dp"
                android:clipToPadding="false"
                android:scrollbarStyle="outsideOverlay" />

            <!-- Empty view -->
            <TextView
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/empty_transactions"
                android:textColor="#7A7F8A"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- CARD: Thanh nút hành động -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_round"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:elevation="2dp">

            <Button
                android:id="@+id/btnAddTransaction"
                android:text="@string/btn_add"
                android:background="@drawable/ripple_chip_action"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:minHeight="0dp"
                android:layout_height="44dp"
                android:layout_width="0dp"
                android:layout_weight="1" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnBackHomeList"
                android:text="@string/btn_back_home"
                android:background="@drawable/ripple_btn_outline"
                android:textColor="#6A75D6"
                android:textAllCaps="false"
                android:minHeight="0dp"
                android:layout_height="44dp"
                android:layout_width="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
