<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F8FA"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- CARD: Tiêu đề & mô tả -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_round"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_recurring_income"
                android:textStyle="bold"
                android:textColor="#2C2C2C"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvSubHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_recurring_income"
                android:textColor="#7A7F8A"
                android:textSize="12sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CARD: Form thêm/sửa -->
        <LinearLayout
            android:id="@+id/cardForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_round"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <!-- Hàng: Danh mục -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:srcCompat="@android:drawable/ic_menu_agenda"
                    app:tint="#6A75D6"
                    android:contentDescription="@string/label_category"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_category"
                    android:textColor="#2C2C2C"
                    android:layout_marginStart="8dp"/>

                <Spinner
                    android:id="@+id/spIncomeCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Hàng: Số tiền -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:srcCompat="@android:drawable/ic_menu_edit"
                    app:tint="#6A75D6"
                    android:contentDescription="@string/label_amount"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_amount"
                    android:textColor="#2C2C2C"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etIncomeAmount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_edittext"
                    android:padding="14dp"
                    android:inputType="number"
                    android:hint="@string/hint_income_amount"/>
            </LinearLayout>

            <!-- Hàng: Ngày bắt đầu (sẽ suy ra ngày nhận hàng tháng) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:srcCompat="@android:drawable/ic_menu_my_calendar"
                    app:tint="#6A75D6"
                    android:contentDescription="@string/label_start_date"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_start_date"
                    android:textColor="#2C2C2C"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_edittext"
                    android:padding="14dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="@string/hint_start_date"/>

                <ImageButton
                    android:id="@+id/btnPickStartDate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/desc_pick_date"
                    app:srcCompat="@android:drawable/ic_menu_month"
                    app:tint="#2C2C2C"/>
            </LinearLayout>

            <!-- Hàng: Nút hành động -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnAddRecurring"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/btn_add_recurring"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/ripple_btn_primary"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp"/>

                <Button
                    android:id="@+id/btnBackHome"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/btn_back_home"
                    android:textAllCaps="false"
                    android:textColor="#6A75D6"
                    android:background="@drawable/ripple_btn_outline"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD: Danh sách đã thêm -->
        <LinearLayout
            android:id="@+id/cardList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_round"
            android:orientation="vertical"
            android:padding="12dp"
            android:elevation="2dp">

            <!-- Header list + nút thu gọn/mở rộng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_recurring_list"
                    android:textStyle="bold"
                    android:textColor="#2C2C2C"/>

                <Button
                    android:id="@+id/btnToggleList"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:text="@string/btn_expand_list"
                    android:background="@drawable/ripple_btn_outline"
                    android:textColor="#6A75D6"/>
            </LinearLayout>

            <ListView
                android:id="@+id/lvRecurring"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
