<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">

    <!-- Camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000"/>

    <!-- Action bar dưới preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnRetake"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ocr_retake"
            android:visibility="gone"/>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ocr_capture"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:visibility="gone"/>

    <!-- OCR + form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Ảnh đã lưu -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ocr_image_saved_to"/>
            <TextView
                android:id="@+id/tvImgPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#475569"
                android:textStyle="italic"
                android:layout_marginBottom="6dp"/>

            <!-- Kết quả OCR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ocr_result_title"/>
            <TextView
                android:id="@+id/tvOcr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1f2937"
                android:minHeight="40dp"
                android:layout_marginBottom="8dp"/>

            <!-- Loại giao dịch -->
            <RadioGroup
                android:id="@+id/rgType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <RadioButton
                    android:id="@+id/rbExpense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/opt_expense"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rbIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/opt_income"
                    android:layout_marginStart="24dp"/>
            </RadioGroup>

            <!-- Số tiền -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/label_amount"/>
            <EditText android:id="@+id/etAmount"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_amount"
                android:inputType="number"
                android:layout_marginBottom="6dp"/>

            <!-- Ngày -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/label_date"/>
            <EditText android:id="@+id/etDate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_date"
                android:layout_marginBottom="6dp"/>

            <!-- Cửa hàng -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/label_merchant"/>
            <EditText android:id="@+id/etMerchant"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_merchant"
                android:layout_marginBottom="6dp"/>

            <!-- Danh mục -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/label_category"/>
            <AutoCompleteTextView android:id="@+id/etCategory"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_category_name"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ocr_save_both"
                android:enabled="false"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
